<!DOCTYPE html>
<html>
<head>
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Wingo</title>
<style>
body{
margin:0;
font-family:Arial,sans-serif;
background:#f5f5f5;
}
.header{
background:#ff6b6b;
color:white;
padding:15px;
text-align:center;
font-size:28px;
font-weight:bold;
}
.balance{
background:white;
margin:15px;
padding:15px;
border-radius:15px;
text-align:center;
font-size:24px;
font-weight:bold;
}
.tabs{
display:flex;
margin:15px;
gap:10px;
}
.tab{
flex:1;
padding:12px;
border-radius:12px;
text-align:center;
background:white;
font-weight:bold;
}
.active{
background:#ff6b6b;
color:white;
}
.timer{
background:white;
margin:15px;
padding:20px;
border-radius:15px;
text-align:center;
}
#countdown{
font-size:40px;
font-weight:bold;
color:#ff6b6b;
}
.colors{
display:flex;
gap:10px;
padding:15px;
}
.colors button{
flex:1;
padding:15px;
border:none;
border-radius:12px;
color:white;
font-size:18px;
font-weight:bold;
}
.green{background:#22c55e;}
.violet{background:#a855f7;}
.red{background:#ef4444;}
.numbers{
display:grid;
grid-template-columns:repeat(5,1fr);
gap:10px;
padding:15px;
}
.numbers button{
height:60px;
border:none;
border-radius:50%;
font-size:22px;
font-weight:bold;
color:white;
}
.num-red{
background:#ef4444;
}
.num-green{
background:#22c55e;
}
.bigsmall{
display:flex;
padding:15px;
gap:10px;
}
.bigsmall button{
flex:1;
padding:15px;
border:none;
border-radius:12px;
font-size:20px;
font-weight:bold;
color:white;
}
.big{
background:#f59e0b;
}
.small{
background:#3b82f6;
}
.history{
background:white;
margin:15px;
padding:15px;
border-radius:15px;
}
.row{
display:flex;
justify-content:space-between;
padding:10px 0;
border-bottom:1px solid #eee;
}
</style>
</head>
<body>
<div class="header">
WINGO
</div>
<div class="balance">
Coins: <span id="coins">1000</span>
</div>
<div class="tabs">
<div class="tab active">30 Sec</div>
<div class="tab">1 Min</div>
</div>
<div class="timer">
<div>Next Round</div>
<div id="countdown">30</div>
</div>
<div class="colors">
<button class="green">Green</button>
<button class="violet">Violet</button>
<button class="red">Red</button>
</div>
<div class="numbers">
<button class="num-red">0</button>
<button class="num-green">1</button>
<button class="num-red">2</button>
<button class="num-green">3</button>
<button class="num-red">4</button>
<button class="num-green">5</button>
<button class="num-red">6</button>
<button class="num-green">7</button>
<button class="num-red">8</button>
<button class="num-green">9</button>
</div>
<div class="bigsmall">
<button class="big">BIG</button>
<button class="small">SMALL</button>
</div>
<div class="history">
<h3>History</h3>
<div class="row">
<span>Round #1001</span>
<span>7</span>
</div>
<div class="row">
<span>Round #1000</span>
<span>2</span>
</div>
<div class="row">
<span>Round #999</span>
<span>5</span>
</div>
</div>
<script>
let time = 30;
setInterval(function(){
time--;
if(time < 0){
time = 30;
}
document.getElementById("countdown").innerHTML = time;
},1000);
</script>
</body>
</html>
